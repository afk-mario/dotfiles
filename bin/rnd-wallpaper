#!/bin/bash
# set -x

OLD_PID="$(pidof swaybg)"
WALL_PATH="$(find "/mnt/2TB/Dropbox/Media/Wallpapers/4k/" \
  -type f \( -name '*.jpg' -o -name '*.png' -o -name '*.webp' \) | shuf -n 1)"

echo "path: $WALL_PATH"

swaybg -m fill -i "$WALL_PATH" &

if [[ -n $OLD_PID ]]; then
  echo pid "old: $OLD_PID"
  sleep 1
  for pid in $OLD_PID; do
    kill "$pid"
  done
fi
